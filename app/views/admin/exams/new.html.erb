  <main class="d-flex body-font">
    <%= render 'common/side' %>
    <div class="flex-grow-1">
      <%= render 'common/header'%>
      <main class="container-fluid py-4 px-4">
        <div>
          <form id="examForm" action="" method="post" class="php-email-form">
            <div class="card">
              <div class="card-header"> Exam Information </div>
              <div class="card-body">
                <div class="row gy-3">
                  <div class="col-md-6">
                    <input type="text" class="form-control" id="examTitle" name="examTitle" placeholder="Exam Title" required>
                  </div>
                  <div class="col-md-6">
                    <input type="number" class="form-control" id="examDuration" name="examDuration" placeholder="Duration (minutes)" min="1" required>
                  </div>
                </div>
                <div class="mb-3 mt-3">
                  <textarea class="form-control" id="examDescription" name="examDescription" rows="3" placeholder="Exam Description"></textarea>
                </div>
                <div class="mb-3">
                  <input type="number" class="form-control" id="examTotalMarks" name="examTotalMarks" placeholder="Total Marks (Overall Exam)" min="0" required>
                </div>
                <div class="mb-3">
                  <label for="examImage" class="form-label">Upload Exam Header Image (Optional)</label>
                  <input class="form-control" type="file" id="examImage" name="examImage" accept="image/*">
                  <div class="form-text">Max 2MB. Recommended for branding or visual context.</div>
                </div>
              </div>
            </div>
            <div class="card">
              <div class="card-header bg-info"> Questions <button type="button" class="btn btn-light btn-sm" id="addQuestionBtn">Add Question</button>
              </div>
              <div class="card-body" id="questionsContainer">
                <p class="text-muted text-center" id="noQuestionsMessage">Click "Add Question" to start adding questions.</p>
                <hr class="my-3">
                <div class="mb-3">
                  <label for="csvFileInput" class="form-label">Import Questions from CSV</label>
                  <input class="form-control" type="file" id="csvFileInput" accept=".csv">
                  <div class="form-text"> Upload a CSV file to import multiple questions. <br> **CSV Format (Headers are ignored, order matters):** `Question Text,Type,Marks,Option1,Option2,Option3,Option4,Correct Answer` <br> Example Row: `"What is 2+2?",mcq,1,"3","4","5","6","4"` <br> Example Row: `"The capital of France is ______.",fill_blanks,1,"Paris"` <br> Example Row: `"Water boils at 100 degrees Celsius.",true_false,1,"True"` </div>
                  <button type="button" class="btn btn-primary mt-3" id="importCsvBtn">Import CSV Questions</button>
                </div>
                <hr class="my-3">
              </div>
            </div>
            <div class="text-center">
              <div class="loading"></div>
              <div class="error-message"></div>
              <div class="sent-message"></div>
              <button type="submit" class="btn btn-success btn-lg me-3">Save Exam</button>
              <button type="reset" class="btn btn-secondary btn-lg">Reset Form</button>
            </div>
          </form>
        </div>
      </main>
    </div>
  </main>




      <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Poppins', sans-serif;
            color: #343a40;
            padding: 15px; /* Reduced body padding */
        }
        .container {
            max-width: 850px; /* Reduced max-width */
            margin-top: 3rem; /* Reduced top margin */
            margin-bottom: 3rem; /* Reduced bottom margin */
        }
        h2 {
            font-weight: 700;
            color: #212529;
            margin-bottom: 0.8rem; /* Reduced margin */
            font-size: 2rem; /* Slightly smaller heading */
        }
        .form-description {
            color: #6c757d;
            font-size: 1rem; /* Smaller font size */
            margin-bottom: 2rem; /* Reduced spacing */
        }

        .card {
            border: none;
            border-radius: 8px; /* Slightly smaller border-radius */
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.06); /* Lighter, less spread shadow */
