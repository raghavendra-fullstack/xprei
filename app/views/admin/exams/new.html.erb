                        // questionCount = 0; // Reset counter for new form
                        // addQuestion(); // Add initial question again
                    } else {
                        showFeedback('error', 'Simulated API failure. Please try again.');
                    }
                }, 1500); // Simulate 1.5 seconds network delay

                // In a real application, you'd use fetch or XMLHttpRequest like this:
                /*
                fetch('/api/exams', { // Your backend endpoint
